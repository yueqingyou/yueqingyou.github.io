{
  "redirects": [
    {
      "source": "/:path((?!en/).*)",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "en.*"
        }
      ],
      "destination": "/en/:path*",
      "permanent": false
    },
    {
      "source": "/en/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": "zh.*"
        }
      ],
      "destination": "/:path((?!en/).*)",
      "permanent": false
    }
  ]
}